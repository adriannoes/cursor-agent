# Spike convenience — flat vars below. Canonical config prefix is CURSOR_AGENT__*
# per ADR-007 (e.g. CURSOR_AGENT__API_KEY); full loader lands in Fase 1.

# Required — user or service-account API key from https://cursor.com/dashboard/api
CURSOR_API_KEY=

# Optional — Telegram bot token from BotFather for gateway polling
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Optional — default workspace for local agents
CURSOR_AGENT_WORKSPACE=.

# Optional — path to config file (default: ~/.cursor-agent/config.yaml)
# CURSOR_AGENT_CONFIG=

# Optional — SQLite session store (default: ~/.cursor-agent/sessions.db)
# CURSOR_AGENT_SESSIONS_DB=

# Optional — directory containing USER.md and MEMORY.md (default: ~/.cursor-agent)
# CURSOR_AGENT__MEMORY_ROOT=/path/to/memory

# Optional SDK debug logging: debug | info
# CURSOR_SDK_LOG=info
