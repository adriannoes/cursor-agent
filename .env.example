# Environment variables for local development. Canonical config prefix is
# CURSOR_AGENT__* per ADR-007; CURSOR_API_KEY is the SDK exception (no prefix).

# Required — user or service-account API key from https://cursor.com/dashboard/api
CURSOR_API_KEY=

# Optional — Telegram bot token from BotFather for gateway polling
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Optional — default workspace for local agents (ADR-007 nested env)
# CURSOR_AGENT__RUNTIME__LOCAL__CWD=.

# Optional — model id (default: composer-2.5)
# CURSOR_AGENT__MODEL=composer-2.5

# Optional — tool profile: coding | messaging (default: coding)
# CURSOR_AGENT__TOOL_PROFILE=coding

# Optional — SQLite session store (default: ~/.cursor-agent/sessions.db)
# CURSOR_AGENT_SESSIONS_DB=

# Optional — directory containing USER.md and MEMORY.md (default: ~/.cursor-agent)
# CURSOR_AGENT__MEMORY_ROOT=/path/to/memory

# Optional SDK debug logging: debug | info
# CURSOR_SDK_LOG=info
